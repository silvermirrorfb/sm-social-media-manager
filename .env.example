# ─── Meta / Instagram ───────────────────────────────────────
# From Meta Developer Dashboard → Your App → Settings
# Preferred names (match current Vercel setup)
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCOUNT=
FACEBOOK_APP_SECRET=

# Legacy fallback names still supported
META_APP_SECRET=
META_VERIFY_TOKEN=silvermirror-ig-webhook-2025
INSTAGRAM_ACCESS_TOKEN=
# Must be the numeric Instagram account ID, not the @username
INSTAGRAM_ACCOUNT_ID=

# ─── Facebook Page ─────────────────────────────────────────
# From Meta Developer Dashboard → Your App → Use Cases → Manage Page
# Page Access Token (long-lived recommended)
FACEBOOK_PAGE_ACCESS_TOKEN=
# Numeric Facebook Page ID
FACEBOOK_PAGE_ID=

# ─── TikTok ────────────────────────────────────────────────
# From TikTok for Developers → App details → Credentials
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Optional override for requested scopes (comma-separated)
# Default: user.info.profile,video.list
TIKTOK_SCOPES=
# Optional encryption key for TikTok OAuth session cookie.
# If blank, app falls back to DASHBOARD_PASSWORD / INSTAGRAM_APP_SECRET / META_APP_SECRET.
TIKTOK_SESSION_SECRET=

# ─── Claude API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Google Sheets Logging ──────────────────────────────────
# Option 1 (same as cancel bot): single JSON blob
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option 2 (alternative): separate fields
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=

# Moderation + activity log sheet (reviewed by Sierra Case)
# https://docs.google.com/spreadsheets/d/1iIDXOE5_PDFllHGzMj6Wuswws9vStrdLMt4swpGR3PY/
GOOGLE_SHEET_ID=1iIDXOE5_PDFllHGzMj6Wuswws9vStrdLMt4swpGR3PY

# ─── Email Alerts (optional, used for moderation alerts) ────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── App ────────────────────────────────────────────────────
# Optional dashboard auth override. If left blank, the deployed app uses the
# built-in protected fallback credentials already configured in code.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
# Optional canonical URL used for OAuth redirects if auto-detection is not desired
APP_BASE_URL=

NODE_ENV=production
